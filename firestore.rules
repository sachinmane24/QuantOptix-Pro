rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isGuest(userId) {
      return userId == 'guest_institutional_trader';
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || (userId == 'guest_institutional_trader');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidTrade(data) {
      // Basic existence check to prevent silent failures
      return data.keys().hasAll(['userId', 'symbol', 'qty', 'entry', 'status']);
    }

    function isValidPortfolio(data) {
      return isOwner(data.userId);
    }

    // --- Collections ---

    match /trades/{tradeId} {
      allow list: if isOwner(resource.data.userId);
      allow get: if isOwner(resource.data.userId);
      allow create: if isOwner(incoming().userId) && isValidTrade(incoming());
      allow update: if isOwner(existing().userId);
      allow delete: if false;
    }

    match /portfolios/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }
  }
}
