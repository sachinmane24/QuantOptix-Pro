rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isGuest(userId) {
      return userId == 'guest_institutional_trader';
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || (userId == 'guest_institutional_trader');
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidTrade(data) {
      // Identity Check: Let create go through if it's the guest or the current user
      // We will rely on the collection-level rules for read/update security
      let hasCoreData = data.symbol is string && 
                         data.qty is number && 
                         data.entry is number && 
                         data.status in ['OPEN', 'CLOSED'];

      return hasCoreData;
    }

    function isValidPortfolio(data) {
      let matchesUser = (data.userId == 'guest_institutional_trader') || (request.auth != null && data.userId == request.auth.uid);
      return matchesUser && data.balance is number;
    }

    function isValidSettings(data) {
      let matchesUser = (data.userId == 'guest_institutional_trader') || (request.auth != null && data.userId == request.auth.uid);
      return matchesUser && data.keys().hasAll(['userId', 'killSwitch']);
    }

    // --- Collections ---

    match /trades/{tradeId} {
      allow list: if (request.auth != null && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest_institutional_trader';
      allow get: if (request.auth != null && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest_institutional_trader';
      
      allow create: if isValidTrade(incoming());
      
      allow update: if ((request.auth != null && existing().userId == request.auth.uid) || existing().userId == 'guest_institutional_trader') && 
                      isValidTrade(incoming());
      
      allow delete: if false; // Audit trail: Never delete trades
    }

    match /portfolios/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPortfolio(incoming());
      allow update: if isOwner(userId) && 
                      isValidPortfolio(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasAny(['balance', 'totalTrades', 'winRate', 'netPnl']);
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings(incoming());
      allow update: if isOwner(userId) && isValidSettings(incoming());
    }
  }
}
