rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isGuest(userId) {
      return userId == 'guest_institutional_trader';
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return (isSignedIn() && request.auth.uid == userId) || isGuest(userId);
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidTrade(data) {
      // Must have core fields
      let hasRequired = data.keys().hasAll(['userId', 'symbol', 'type', 'entry', 'sl', 'qty', 'status', 'timestamp', 'optionType', 'strike', 'targets', 'pnl', 'currentPrice', 'prob']);
      
      // Ownership check
      let matchesUser = (data.userId == (request.auth != null ? request.auth.uid : 'guest_institutional_trader'));
      
      // Field constraints
      let validSymbol = data.symbol is string && data.symbol.size() <= 20;
      let validType = data.type is string && data.type.size() <= 10; // 'BUY CE' or 'BUY PE'
      let validOptionType = data.optionType in ['CE', 'PUT'];
      let validStrike = data.strike is number && data.strike > 0;
      let validNumeric = data.entry is number && data.entry >= 0 && 
                         data.sl is number && data.sl >= 0 && 
                         data.qty is number && data.qty > 0 && 
                         data.pnl is number && 
                         data.currentPrice is number &&
                         data.prob is number && data.prob <= 100;
      let validStatus = data.status in ['OPEN', 'CLOSED'];
      let validTargets = data.targets is list && data.targets.size() <= 5;

      return hasRequired && matchesUser && validSymbol && validType && validOptionType && validStrike && validNumeric && validStatus && validTargets;
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['userId', 'balance']) &&
             (data.userId == (isSignedIn() ? request.auth.uid : 'guest_institutional_trader')) &&
             data.balance is number;
    }

    function isValidSettings(data) {
      // Allow any risk settings as long as they have balance and userId
      return data.keys().hasAll(['userId', 'killSwitch']) &&
             (data.userId == (isSignedIn() ? request.auth.uid : 'guest_institutional_trader')) &&
             data.killSwitch is bool;
    }

    // --- Collections ---

    match /trades/{tradeId} {
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest_institutional_trader';
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest_institutional_trader';
      
      allow create: if (isSignedIn() || (incoming().userId == 'guest_institutional_trader')) && 
                      isValidId(tradeId) && 
                      isValidTrade(incoming());
      
      allow update: if (isOwner(existing().userId)) && 
                      isValidTrade(incoming()) && (
                        // Action: Close Trade
                        (incoming().status == 'CLOSED' && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'pnl', 'exit', 'closedAt'])) ||
                        // Action: Update SL/Targets
                        (incoming().status == 'OPEN' && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['sl', 'targets']))
                      );
      
      allow delete: if false; // Audit trail: Never delete trades
    }

    match /portfolios/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPortfolio(incoming());
      allow update: if isOwner(userId) && 
                      isValidPortfolio(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasAny(['balance', 'totalTrades', 'winRate', 'netPnl']);
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings(incoming());
      allow update: if isOwner(userId) && isValidSettings(incoming());
    }
  }
}
