rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'symbol', 'type', 'entry', 'sl', 'qty', 'status', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.symbol is string && data.symbol.size() <= 20 &&
             data.type in ['BUY_CE', 'BUY_PE'] &&
             data.entry is number && data.entry > 0 &&
             data.sl is number && data.sl >= 0 &&
             data.qty is number && data.qty > 0 &&
             data.status in ['OPEN', 'CLOSED'];
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['userId', 'balance']) &&
             data.userId == request.auth.uid &&
             data.balance is number;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['userId', 'killSwitch']) &&
             data.userId == request.auth.uid &&
             data.killSwitch is bool;
    }

    // --- Collections ---

    match /trades/{tradeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(tradeId) && 
                      isValidTrade(incoming());
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) && 
                      isValidTrade(incoming()) && (
                        // Action: Close Trade
                        (incoming().status == 'CLOSED' && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'pnl', 'exit', 'closedAt'])) ||
                        // Action: Update SL/Targets
                        (incoming().status == 'OPEN' && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['sl', 'targets']))
                      );
      
      allow delete: if false; // Audit trail: Never delete trades
    }

    match /portfolios/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPortfolio(incoming());
      allow update: if isOwner(userId) && 
                      isValidPortfolio(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasAny(['balance', 'totalTrades', 'winRate', 'netPnl']);
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings(incoming());
      allow update: if isOwner(userId) && isValidSettings(incoming());
    }
  }
}
